# Camera backend: "picamera2" or "opencv" (auto-detect if unset)
# CAMERA_BACKEND=opencv

# Camera device index for OpenCV (default: 0)
# CAMERA_DEVICE_INDEX=0

# Server host and port
# HOST=0.0.0.0
# PORT=8000

# Frame dimensions
# FRAME_WIDTH=640
# FRAME_HEIGHT=480

# Target FPS for streaming
# STREAM_FPS=15

# Access code file path (relative to project root)
# ACCESS_CODE_FILE=data/access_code.txt

# Default access code (used when file doesn't exist)
# DEFAULT_ACCESS_CODE=0000

# GPIO pin (BCM numbering) for door unlock
# GPIO_PIN=17

# Duration in seconds to keep GPIO HIGH on unlock
# GPIO_UNLOCK_DURATION=5
